{
  "name": "traveloop-backend",
  "version": "1.0.0",
  "description": "Production-grade REST API backend for Traveloop travel planning platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:create": "npx sequelize-cli db:create",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:migrate:undo": "npx sequelize-cli db:migrate:undo:all",
    "db:seed:cities": "npx sequelize-cli db:seed --seed seeders/cities.seeder.js",
    "db:seed:activities": "npx sequelize-cli db:seed --seed seeders/activities.seeder.js",
    "db:seed:admin": "npx sequelize-cli db:seed --seed seeders/admin.seeder.js",
    "db:seed:sample": "npx sequelize-cli db:seed --seed seeders/sample.seeder.js",
    "db:seed:all": "npm run db:seed:cities && npm run db:seed:activities && npm run db:seed:admin && npm run db:seed:sample",
    "db:init": "npm run db:create && npm run db:migrate && npm run db:seed:all",
    "db:reset": "npm run db:migrate:undo && npm run db:migrate && npm run db:seed:all"
  },
  "keywords": [
    "travel",
    "api",
    "nodejs",
    "express",
    "mysql"
  ],
  "author": "Traveloop Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "joi": "^17.9.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.0.0",
    "nodemailer": "^6.9.0",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "sequelize": "^6.32.0",
    "socket.io": "^4.6.0",
    "swagger-jsdoc": "^6.2.0",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "sequelize-cli": "^6.6.5"
  }
}
